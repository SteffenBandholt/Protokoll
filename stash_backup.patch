index 0000000..77df762
--- /dev/null
+++ b/src/main/ipc/shellIpc.js
@@ -0,0 +1,33 @@
+// TECH-CONTRACT (verbindlich): docs/UI-TECH-CONTRACT.md
+// CONTRACT-VERSION: 1.0.0
+// src/main/ipc/shellIpc.js
+
+const { ipcMain, shell } = require("electron");
+
+function registerShellIpc() {
+  // payload: { url: "mailto:..." }
+  ipcMain.handle("shell:openExternal", async (_e, payload) => {
+    try {
+      const url = String(payload?.url || "").trim();
+      if (!url) return { ok: false, error: "URL fehlt." };
+      await shell.openExternal(url);
+      return { ok: true };
+    } catch (err) {
+      return { ok: false, error: err?.message || String(err) };
+    }
+  });
+
+  // payload: { path: "C:/..." }
+  ipcMain.handle("shell:showItemInFolder", async (_e, payload) => {
+    try {
+      const p = String(payload?.path || "").trim();
+      if (!p) return { ok: false, error: "Pfad fehlt." };
+      shell.showItemInFolder(p);
+      return { ok: true };
+    } catch (err) {
+      return { ok: false, error: err?.message || String(err) };
+    }
+  });
+}
+
+module.exports = { registerShellIpc };
