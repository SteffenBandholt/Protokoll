{
  "name": "bbm-protokoll",
  "version": "1.2.2",
  "description": "BBM - Protokoll",
  "author": "Steffen Bandholt",
  "main": "src/main/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "node scripts/test.cjs",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" --fix",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2"
  },
  "build": {
    "appId": "de.bbm.Protokoll",
    "productName": "BBM",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "build/bbm-icon.ico",
      "!src/main/db/app.db",
      "!**/backups/**",
      "!**/*.db",
      "!**/*.sqlite",
      "!**/*.sqlite3"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "win": {
      "icon": "build/bbm-icon.ico",
      "target": [
        "portable",
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "build/nsis-icon.ico",
      "uninstallerIcon": "build/nsis-icon.ico",
      "installerHeaderIcon": "build/nsis-icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BBM"
    }
  }
}
