# Lokale Entwicklerkonfiguration fuer Audio-Transkription
# Relative _PATH-Werte werden beim App-Start gegen das Projektverzeichnis aufgeloest.

BBM_WHISPER_CPP_PATH=dev/tools/whisper.cpp/Release/whisper-cli.exe
BBM_WHISPER_MODEL_PATH=dev/models/ggml-base.bin

# Optional fuer mp3/mp4/m4a und andere Nicht-WAV-Dateien
# BBM_FFMPEG_PATH=C:/Tools/ffmpeg/bin/ffmpeg.exe

# Kompatible Fallbacks, falls BBM_-Varianten nicht gesetzt sind:
# WHISPER_CPP_PATH=...
# WHISPER_MODEL_PATH=...
# FFMPEG_PATH=...
